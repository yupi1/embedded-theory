<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Фронт сигналу · Конспект · Embedded Systems</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-base:      #0d0f10;
      --bg-surface:   #141618;
      --bg-elevated:  #1a1d20;
      --bg-overlay:   #21252a;

      --border-dim:    rgba(255,255,255,0.06);
      --border-mid:    rgba(255,255,255,0.12);
      --border-bright: rgba(255,255,255,0.22);

      --text-primary:   #e8e6e0;
      --text-secondary: #8b897e;
      --text-muted:     #52504a;
      --text-inverse:   #0d0f10;

      --accent:      #00d084;
      --accent-dim:  rgba(0,208,132,0.12);
      --accent-mid:  rgba(0,208,132,0.25);
      --accent-glow: rgba(0,208,132,0.06);

      --rising:  #00d084;
      --falling: #ff6b4a;
      --clk:     #4a9eff;
      --warning: #f5c842;
      --danger:  #ff4a4a;

      --font-mono: 'JetBrains Mono', 'Courier New', monospace;
      --font-sans: 'IBM Plex Sans', system-ui, sans-serif;

      --r-sm: 4px;  --r-md: 6px;  --r-lg: 10px;  --r-xl: 14px;

      --text-xs:  11px;  --text-sm:  12px;  --text-base: 14px;
      --text-md:  15px;  --text-lg:  17px;  --text-xl:   20px;
      --text-2xl: 24px;  --text-3xl: 30px;  --text-4xl:  38px;

      --glow-accent: 0 0 20px rgba(0,208,132,0.15);

      /* Фронти сигналу → категорія MCU → falling (помаранчевий) */
      --topic-color: var(--falling);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg-base);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: var(--text-base);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    .ic {
      font-family: var(--font-mono);
      font-size: var(--text-sm);
      background: var(--bg-elevated);
      border: 1px solid var(--border-dim);
      padding: 2px 6px;
      border-radius: var(--r-sm);
      color: var(--accent);
    }

    .badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 8px; border-radius: 3px; font-family: var(--font-mono); font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; white-space: nowrap; }
    .badge::before { content: ''; display: block; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
    .badge-pill    { border-radius: 100px; }
    .badge-rising  { background: rgba(0,208,132,0.12);  color: var(--rising);  border: 1px solid rgba(0,208,132,0.25); }
    .badge-falling { background: rgba(255,107,74,0.12); color: var(--falling); border: 1px solid rgba(255,107,74,0.25); }
    .badge-clk     { background: rgba(74,158,255,0.12); color: var(--clk);     border: 1px solid rgba(74,158,255,0.25); }
    .badge-warning { background: rgba(245,200,66,0.12); color: var(--warning); border: 1px solid rgba(245,200,66,0.25); }
    .badge-neutral { background: var(--bg-elevated); color: var(--text-secondary); border: 1px solid var(--border-dim); }

    .callout { border-radius: var(--r-lg); padding: 14px 16px; display: flex; gap: 12px; font-size: var(--text-base); line-height: 1.6; }
    .callout-icon { font-family: var(--font-mono); font-size: 10px; font-weight: 700; padding: 3px 6px; border-radius: 3px; flex-shrink: 0; margin-top: 1px; }
    .callout-info      { background: rgba(74,158,255,0.07);  border: 1px solid rgba(74,158,255,0.18);  color: var(--text-secondary); }
    .callout-info      .callout-icon { background: rgba(74,158,255,0.2); color: var(--clk); }
    .callout-warning   { background: rgba(245,200,66,0.07);  border: 1px solid rgba(245,200,66,0.18);  color: var(--text-secondary); }
    .callout-warning   .callout-icon { background: rgba(245,200,66,0.2); color: var(--warning); }
    .callout-important { background: rgba(0,208,132,0.05);   border: 1px solid rgba(0,208,132,0.15);   color: var(--text-secondary); }
    .callout-important .callout-icon { background: var(--accent-dim); color: var(--accent); }
    .callout-danger    { background: rgba(255,74,74,0.07);   border: 1px solid rgba(255,74,74,0.18);   color: var(--text-secondary); }
    .callout-danger    .callout-icon { background: rgba(255,74,74,0.2); color: var(--danger); }
    .callout strong { color: var(--text-primary); }

    .code-block { background: var(--bg-surface); border: 1px solid var(--border-dim); border-radius: var(--r-lg); overflow: hidden; font-family: var(--font-mono); font-size: var(--text-sm); }
    .code-block-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px solid var(--border-dim); background: var(--bg-elevated); }
    .code-block-lang   { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
    .code-block-copy   { font-size: 10px; color: var(--text-muted); cursor: pointer; background: none; border: none; font-family: var(--font-mono); padding: 0; transition: color 0.15s; }
    .code-block-copy:hover { color: var(--accent); }
    .code-block-body   { padding: 16px; line-height: 1.65; overflow-x: auto; color: var(--text-primary); }
    .code-block-body .kw  { color: var(--clk); }
    .code-block-body .fn  { color: var(--accent); }
    .code-block-body .str { color: var(--warning); }
    .code-block-body .cm  { color: var(--text-muted); font-style: italic; }
    .code-block-body .num { color: var(--falling); }
    .code-block-body .reg { color: var(--warning); }

    .table-wrap { background: var(--bg-surface); border: 1px solid var(--border-dim); border-radius: var(--r-xl); overflow: hidden; }
    .kit-table  { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
    .kit-table thead tr { border-bottom: 1px solid var(--border-mid); }
    .kit-table th  { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); padding: 12px 16px; text-align: left; font-weight: 500; }
    .kit-table td  { padding: 11px 16px; color: var(--text-secondary); border-bottom: 1px solid var(--border-dim); vertical-align: middle; }
    .kit-table tr:last-child td { border-bottom: none; }
    .kit-table tr:hover td { background: rgba(255,255,255,0.02); }
    .kit-table .mono   { font-family: var(--font-mono); color: var(--text-primary); }
    .kit-table .accent { color: var(--accent); font-family: var(--font-mono); }
    .kit-table .falling { color: var(--falling); font-family: var(--font-mono); }
    .kit-table .clk-c   { color: var(--clk); font-family: var(--font-mono); }
    .kit-table .warn-c  { color: var(--warning); font-family: var(--font-mono); }

    .stat-card  { background: var(--bg-elevated); border: 1px solid var(--border-dim); border-radius: var(--r-lg); padding: 18px 20px; }
    .stat-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
    .stat-value { font-family: var(--font-mono); font-size: var(--text-2xl); font-weight: 500; color: var(--text-primary); }
    .stat-unit  { font-size: var(--text-sm); color: var(--text-muted); margin-left: 4px; }
    .stat-sub   { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-top: 4px; }

    .accordion { border: 1px solid var(--border-dim); border-radius: var(--r-xl); overflow: hidden; background: var(--bg-surface); }
    .accordion-item { border-bottom: 1px solid var(--border-dim); }
    .accordion-item:last-child { border-bottom: none; }
    .accordion-trigger { width: 100%; background: none; border: none; padding: 18px 20px; text-align: left; cursor: pointer; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; transition: background 0.15s; color: var(--text-primary); font-size: var(--text-base); font-family: var(--font-sans); }
    .accordion-trigger:hover { background: var(--border-dim); }
    .accordion-trigger.open  { background: var(--accent-glow); }
    .accordion-icon { flex-shrink: 0; width: 20px; height: 20px; border-radius: 50%; border: 1px solid var(--border-mid); display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--text-secondary); transition: transform 0.25s, border-color 0.2s, color 0.2s; margin-top: 2px; }
    .accordion-trigger.open .accordion-icon { transform: rotate(45deg); border-color: var(--accent); color: var(--accent); }
    .accordion-body { overflow: hidden; max-height: 0; transition: max-height 0.35s ease; background: var(--accent-glow); }
    .accordion-body.open { max-height: 800px; }
    .accordion-content { padding: 4px 20px 20px; color: var(--text-secondary); font-size: var(--text-base); line-height: 1.7; border-top: 1px solid var(--border-dim); }
    .accordion-content strong { color: var(--text-primary); font-weight: 500; }
    .accordion-content p { margin-top: 10px; }
    .accordion-content p:first-child { margin-top: 0; }

    .waveform-demo   { background: var(--bg-surface); border: 1px solid var(--border-dim); border-radius: var(--r-xl); overflow: hidden; }
    .waveform-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px solid var(--border-dim); background: var(--bg-elevated); }
    .waveform-title  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }
    .waveform-body   { padding: 16px; }
    .waveform-svg    { display: block; width: 100%; }

    /* canvas waveform */
    .waveform-canvas-wrap { position: relative; }
    .waveform-canvas-wrap canvas { display: block; width: 100%; }

    /* controls */
    .wave-controls { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; padding: 12px 16px; border-top: 1px solid var(--border-dim); background: var(--bg-elevated); }
    .wave-btn { background: none; border: 1px solid var(--border-mid); color: var(--text-secondary); font-family: var(--font-mono); font-size: 10px; padding: 5px 12px; border-radius: var(--r-md); cursor: pointer; transition: all 0.15s; text-transform: uppercase; letter-spacing: 0.08em; }
    .wave-btn:hover { border-color: var(--topic-color); color: var(--topic-color); }
    .wave-btn.active { border-color: var(--topic-color); color: var(--topic-color); background: rgba(255,107,74,0.08); }
    .wave-slider-wrap { display: flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); }
    input[type=range] { -webkit-appearance: none; width: 100px; height: 3px; background: var(--border-mid); border-radius: 2px; outline: none; }
    input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%; background: var(--topic-color); cursor: pointer; }
    #slopeVal { color: var(--topic-color); min-width: 32px; }

    /* topic lists */
    .topic-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .topic-list li { display: flex; gap: 10px; font-size: var(--text-base); color: var(--text-secondary); line-height: 1.6; }
    .topic-list li::before { content: '—'; color: var(--topic-color); flex-shrink: 0; font-family: var(--font-mono); }
    .topic-list li strong { color: var(--text-primary); }

    .steps-list { list-style: none; display: flex; flex-direction: column; gap: 10px; counter-reset: steps; }
    .steps-list li { display: flex; gap: 12px; font-size: var(--text-base); color: var(--text-secondary); line-height: 1.6; counter-increment: steps; }
    .steps-list li::before { content: counter(steps); flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%; background: var(--bg-elevated); border: 1px solid var(--border-mid); font-family: var(--font-mono); font-size: 10px; color: var(--topic-color); display: flex; align-items: center; justify-content: center; margin-top: 2px; }
    .steps-list li strong { color: var(--text-primary); }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }

    /* page structure */
    .page-top-line { height: 2px; background: linear-gradient(90deg, var(--topic-color) 0%, transparent 60%); }
    .page-wrap { max-width: 820px; margin: 0 auto; padding: 56px 40px 120px; }
    .page-header { border-bottom: 1px solid var(--border-dim); padding-bottom: 48px; margin-bottom: 56px; }
    .page-eyebrow { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--text-muted); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .page-eyebrow::before { content: '//'; color: var(--topic-color); font-size: 12px; }
    .page-title { font-size: clamp(32px, 5vw, 50px); font-weight: 300; color: var(--text-primary); line-height: 1.1; margin-bottom: 16px; }
    .page-title-accent { color: var(--topic-color); }
    .page-desc { font-size: var(--text-lg); color: var(--text-secondary); max-width: 560px; line-height: 1.65; margin-bottom: 20px; }
    .page-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .section-header { display: flex; align-items: baseline; gap: 14px; margin-bottom: 20px; margin-top: 56px; }
    .section-num  { font-family: var(--font-mono); font-size: 11px; color: var(--topic-color); opacity: 0.7; min-width: 28px; }
    .section-name { font-size: var(--text-xl); font-weight: 400; color: var(--text-primary); }
    .back-link { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; transition: color 0.15s; margin-bottom: 32px; }
    .back-link:hover { color: var(--accent); }
    .page-footer { margin-top: 80px; padding-top: 24px; border-top: 1px solid var(--border-dim); font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.14em; }
    .mt-4  { margin-top: 16px; }
    .mt-6  { margin-top: 24px; }
    .mt-8  { margin-top: 32px; }
    .stack { display: flex; flex-direction: column; gap: 12px; }
    .divider { height: 1px; background: var(--border-dim); margin: 40px 0; }

    /* tooltip */
    #wave-tooltip { position: fixed; background: var(--bg-overlay); border: 1px solid var(--border-mid); border-radius: var(--r-md); padding: 8px 12px; font-family: var(--font-mono); font-size: 11px; pointer-events: none; opacity: 0; transition: opacity 0.1s; z-index: 100; line-height: 1.6; }

    @media (max-width: 600px) {
      .page-wrap { padding: 32px 20px 80px; }
      .grid-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<div id="wave-tooltip"></div>
<div class="page-top-line"></div>

<div class="page-wrap">

  <a class="back-link" href="../index.html">← повернутись до конспекту</a>

  <!-- HEADER -->
  <header class="page-header">
    <div class="page-eyebrow">Конспект · Electronics</div>
    <h1 class="page-title">
      Фронт <span class="page-title-accent">сигналу</span>
    </h1>
    <p class="page-desc">
      Наростаючий та спадаючий фронт — фундаментальна концепція цифрової електроніки.
      Визначає як MCU читає дані, коли спрацьовують переривання та чому
      реєстр <code class="ic">GPIOx_OSPEEDR</code> впливає на надійність схеми.
    </p>
    <div class="page-tags">
      <span class="badge badge-rising badge-pill">learnt</span>
      <span class="badge badge-neutral badge-pill">STM32</span>
      <span class="badge badge-neutral badge-pill">ESP32</span>
      <span class="badge badge-neutral badge-pill">Electronics</span>
    </div>
  </header>


  <!-- 01 — КЛЮЧОВІ ПАРАМЕТРИ -->
  <div class="section-header">
    <span class="section-num">01 —</span>
    <span class="section-name">Ключові параметри</span>
  </div>

  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-label">Rise Time (tᵣ)</div>
      <div class="stat-value">10<span class="stat-unit">→ 90%</span></div>
      <div class="stat-sub">Vcc, стандарт IEEE</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Fall Time (tᶠ)</div>
      <div class="stat-value">90<span class="stat-unit">→ 10%</span></div>
      <div class="stat-sub">Vcc, стандарт IEEE</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">GPIO VERY_HIGH</div>
      <div class="stat-value">100<span class="stat-unit">МГц</span></div>
      <div class="stat-sub">STM32 max slew rate</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">I²C pull-up typ.</div>
      <div class="stat-value">4.7<span class="stat-unit">кОм</span></div>
      <div class="stat-sub">τ = R·C ≈ 47 нс</div>
    </div>
  </div>


  <!-- 02 — ЩО ЦЕ ТАКЕ -->
  <div class="section-header">
    <span class="section-num">02 —</span>
    <span class="section-name">Що це таке</span>
  </div>

  <p style="font-size:var(--text-md); color:var(--text-primary); line-height:1.75;">
    <strong>Фронт сигналу</strong> — перехідний процес зміни цифрового сигналу між рівнями LOW та HIGH.
    На відміну від ідеального прямокутного імпульсу, реальний фронт займає час:
    <code class="ic">tᵣ</code> — наростаючий, <code class="ic">tᶠ</code> — спадаючий.
    Крутизна фронту визначається параметром <strong>Slew Rate</strong> = dV/dt [В/нс].
  </p>

  <div class="mt-8">
    <div class="callout callout-important">
      <span class="callout-icon">KEY</span>
      <div><strong>Ключова ідея:</strong> реальний фронт — не стрибок, а перехідний процес.
      Занадто повільний → помилкові спрацювання EXTI; занадто швидкий → EMI-шум і ringing на лінії.</div>
    </div>
  </div>

  <div class="mt-4">
    <div class="callout callout-info">
      <span class="callout-icon">INF</span>
      <div>Вимірювання tᵣ і tᶠ завжди проводяться між рівнями <strong>10% і 90%</strong> від Vcc — це промисловий
      стандарт IEEE. Крайні точки (0% і 100%) асимптотично наближаються до рівня і їх важко точно
      зафіксувати на осцилографі.</div>
    </div>
  </div>


  <!-- 03 — ІНТЕРАКТИВНА ОСЦИЛОГРАМА -->
  <div class="section-header">
    <span class="section-num">03 —</span>
    <span class="section-name">Інтерактивна осцилограма</span>
  </div>

  <div class="waveform-demo">
    <div class="waveform-header">
      <span class="waveform-title">Waveform Viewer — CLK / DATA / TRIGGER</span>
      <div style="display:flex;gap:8px">
        <span class="badge badge-clk badge-pill" style="font-size:9px">CLK</span>
        <span class="badge badge-rising badge-pill" style="font-size:9px">DATA</span>
        <span class="badge badge-falling badge-pill" style="font-size:9px">TRIGGER</span>
      </div>
    </div>
    <div class="waveform-body waveform-canvas-wrap" style="padding:0;">
      <canvas id="waveCanvas" height="240" style="display:block;width:100%;background:#0d0f10;"></canvas>
    </div>
    <div class="wave-controls">
      <button class="wave-btn active" id="btnPlay">▶ play</button>
      <button class="wave-btn" id="btnPause">⏸ pause</button>
      <button class="wave-btn" id="btnReset">↺ reset</button>
      <div class="wave-slider-wrap">
        <span>Slew Rate</span>
        <input type="range" id="slopeSlider" min="1" max="20" value="6">
        <span id="slopeVal">6 нс</span>
      </div>
    </div>
  </div>
  <p style="font-family:var(--font-mono);font-size:10px;color:var(--text-muted);text-align:center;margin-top:8px;">
    Cyan | вертикальні лінії = наростаючі фронти CLK (POSEDGE). Наведи курсор → рівень та час.
  </p>


  <!-- 04 — TIMING DIAGRAM -->
  <div class="section-header">
    <span class="section-num">04 —</span>
    <span class="section-name">Timing Diagram — tᵣ і tᶠ</span>
  </div>

  <div class="waveform-demo">
    <div class="waveform-header">
      <span class="waveform-title">Rise Time / Fall Time — вимірювання 10%↔90%</span>
      <div style="display:flex;gap:8px">
        <span class="badge badge-rising badge-pill" style="font-size:9px">tᵣ</span>
        <span class="badge badge-falling badge-pill" style="font-size:9px">tᶠ</span>
      </div>
    </div>
    <div class="waveform-body" style="padding:0;">
      <canvas id="timingCanvas" height="180" style="display:block;width:100%;background:#0d0f10;"></canvas>
    </div>
  </div>


  <!-- 05 — ТАБЛИЦЯ ПАРАМЕТРІВ -->
  <div class="section-header">
    <span class="section-num">05 —</span>
    <span class="section-name">Параметри та реєстри</span>
