  <p style="color:var(--text-secondary);font-size:var(--text-base);margin-bottom:16px;">
    Налаштування GPIO на переривання по наростаючому фронту + обробник на STM32 HAL.
  </p>

  <div class="code-block">
    <div class="code-block-header">
      <span class="code-block-lang">C · STM32 HAL</span>
      <button class="code-block-copy">copy</button>
    </div>
    <pre class="code-block-body"><span class="cm">// 1. Налаштування в CubeMX або вручну в MX_GPIO_Init()</span>
<span class="kw">GPIO_InitTypeDef</span> GPIO_InitStruct = {<span class="num">0</span>};

<span class="fn">__HAL_RCC_GPIOA_CLK_ENABLE</span>();

GPIO_InitStruct.<span class="reg">Pin</span>   = <span class="reg">GPIO_PIN_0</span>;
GPIO_InitStruct.<span class="reg">Mode</span>  = <span class="reg">GPIO_MODE_IT_RISING</span>;  <span class="cm">// тригер по RISING</span>
GPIO_InitStruct.<span class="reg">Pull</span>  = <span class="reg">GPIO_PULLDOWN</span>;          <span class="cm">// лінія у спокої LOW</span>
GPIO_InitStruct.<span class="reg">Speed</span> = <span class="reg">GPIO_SPEED_FREQ_LOW</span>;   <span class="cm">// slew rate не критичний</span>
<span class="fn">HAL_GPIO_Init</span>(<span class="reg">GPIOA</span>, &GPIO_InitStruct);

<span class="cm">// 2. Увімкнути переривання у NVIC</span>
<span class="fn">HAL_NVIC_SetPriority</span>(<span class="reg">EXTI0_IRQn</span>, <span class="num">2</span>, <span class="num">0</span>);
<span class="fn">HAL_NVIC_EnableIRQ</span>(<span class="reg">EXTI0_IRQn</span>);

<span class="cm">// 3. Callback — викликається автоматично з EXTI IRQ Handler</span>
<span class="kw">void</span> <span class="fn">HAL_GPIO_EXTI_Callback</span>(<span class="kw">uint16_t</span> GPIO_Pin) {
    <span class="kw">if</span> (GPIO_Pin == <span class="reg">GPIO_PIN_0</span>) {
        <span class="cm">// обробка наростаючого фронту</span>
        rising_edge_count++;
    }
}</pre>
  </div>

  <div class="code-block mt-4">
    <div class="code-block-header">
      <span class="code-block-lang">C · ESP-IDF v5.x</span>
      <button class="code-block-copy">copy</button>
    </div>
    <pre class="code-block-body"><span class="cm">// Налаштування GPIO переривання по будь-якому фронту</span>
<span class="kw">static void</span> <span class="fn">IRAM_ATTR</span> gpio_isr_handler(<span class="kw">void</span>* arg) {
    <span class="kw">uint32_t</span> gpio_num = (<span class="kw">uint32_t</span>) arg;
    <span class="fn">xQueueSendFromISR</span>(gpio_evt_queue, &gpio_num, <span class="num">NULL</span>);
}

<span class="kw">void</span> <span class="fn">app_main</span>(<span class="kw">void</span>) {
    <span class="kw">gpio_config_t</span> io_conf = {
        .<span class="reg">pin_bit_mask</span> = (<span class="num">1ULL</span> << <span class="num">GPIO_NUM_4</span>),
        .<span class="reg">mode</span>         = <span class="reg">GPIO_MODE_INPUT</span>,
        .<span class="reg">pull_up_en</span>   = <span class="reg">GPIO_PULLUP_ENABLE</span>,
        .<span class="reg">intr_type</span>    = <span class="reg">GPIO_INTR_ANYEDGE</span>,  <span class="cm">// RISING + FALLING</span>
    };
    <span class="fn">gpio_config</span>(&io_conf);

    gpio_evt_queue = <span class="fn">xQueueCreate</span>(<span class="num">10</span>, <span class="kw">sizeof</span>(<span class="kw">uint32_t</span>));
    <span class="fn">gpio_install_isr_service</span>(<span class="num">0</span>);
    <span class="fn">gpio_isr_handler_add</span>(<span class="num">GPIO_NUM_4</span>, gpio_isr_handler, (<span class="kw">void</span>*)<span class="num">GPIO_NUM_4</span>);
}</pre>
  </div>


  <!-- 09 — НА ЩО ЗВЕРНУТИ УВАГУ -->
  <div class="section-header">
    <span class="section-num">09 —</span>
    <span class="section-name">На що звернути увагу</span>
  </div>

  <div class="stack">
    <div class="callout callout-warning">
      <span class="callout-icon">WRN</span>
      <div><strong>Дребезг контактів (Bounce):</strong> механічна кнопка генерує 5–50 переходів
      за 5–20 мс. EXTI зафіксує кожен як окремий фронт. Рішення: RC-фільтр (10 кОм + 100 нФ)
      або програмна затримка 20 мс після першого фронту.</div>
    </div>
    <div class="callout callout-warning">
      <span class="callout-icon">WRN</span>
      <div><strong>Ringing після фронту:</strong> крутий фронт створює LC-резонанс між
      індуктивністю доріжки і паразитною ємністю → коливання. На осцилографі: "хвилі" після
      фронту. Може викликати подвійне спрацювання EXTI. Рішення: послідовний резистор
      <strong>22–100 Ом</strong> на виході GPIO.</div>
    </div>
    <div class="callout callout-danger">
      <span class="callout-icon">ERR</span>
      <div><strong>Порушення Setup/Hold Time:</strong> якщо дані не встигли стабілізуватися
      до або після фронту CLK — flip-flop переходить у стан metastability. Вихід зависає
      між 0 і 1 на непередбачений час. Результат: рандомні збої що неможливо відтворити.</div>
    </div>
    <div class="callout callout-info">
      <span class="callout-icon">INF</span>
      <div><strong>EMI та slew rate:</strong> крутий фронт = широкий спектр гармонік (ряд Фур'є).
      Правило: використовуй мінімальний <code class="ic">OSPEEDR</code> що задовольняє вимоги протоколу.
      Для I²C — <code class="ic">LOW</code>, для SPI 10 МГц — <code class="ic">MEDIUM</code>,
      для USB — <code class="ic">VERY_HIGH</code>.</div>
    </div>
  </div>


  <!-- 10 — ПИТАННЯ НА СПІВБЕСІДІ -->
  <div class="section-header">
    <span class="section-num">10 —</span>
    <span class="section-name">Питання на співбесіді</span>
  </div>

  <div class="accordion">

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Чим відрізняється наростаючий фронт від спадаючого? Як їх правильно виміряти?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          <strong>Rising Edge</strong> — перехід LOW→HIGH, <strong>Falling Edge</strong> — HIGH→LOW.
          <p class="mt-6">Вимірюються між рівнями <code class="ic">10%</code> і <code class="ic">90%</code> від Vcc:
          <code class="ic">tᵣ</code> = час від 10% до 90%, <code class="ic">tᶠ</code> = час від 90% до 10%.</p>
          <p class="mt-6">Чому не від 0 до 100%? Краї кривої асимптотично наближаються до рівня —
          їх практично неможливо точно зафіксувати. Діапазон 10–90% є промисловим стандартом IEEE 
          і відтворюється на будь-якому осцилографі.</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Чому у I²C фронти повільніші ніж у SPI? Як тип GPIO виходу впливає на фронт?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          I²C використовує <strong>open-drain</strong>: спадаючий фронт — активний (N-МОП тягне до GND),
          наростаючий — пасивний через pull-up резистор.
          <p class="mt-6">Швидкість наростання визначається RC-константою: <code class="ic">τ = R · C</code>.
          При 4.7 кОм і 10 пФ: τ ≈ 47 нс. З довшими проводами (більша ємність) — ще повільніше.
          Звідси обмеження I²C ~3.4 МГц у Fast Mode Plus.</p>
          <p class="mt-6">SPI — <strong>push-pull</strong>: обидва напрямки активні. Транзистори
          заряджають і розряджають лінію агресивно → фронти в 10–50 разів крутіші → SPI легко
          досягає 40+ МГц.</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Що таке Setup Time і Hold Time? Що трапиться при їх порушенні?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          <strong>Setup Time (tsu)</strong> — мінімальний час, протягом якого дані мають бути стабільними
          <em>до</em> активного фронту CLK. <strong>Hold Time (th)</strong> — мінімальний час
          стабільності даних <em>після</em> фронту CLK.
          <p class="mt-6">Порушення будь-якого з них призводить до <strong>metastability</strong> —
          вихід flip-flop зависає між логічним 0 і 1 на непередбачуваний час. MCU сприйме
          невизначений стан.</p>
          <p class="mt-6">На практиці це проявляється як рандомні збої, які неможливо відтворити
          в лабораторії — один з найнеприємніших типів багів в embedded-розробці.</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Що таке CPOL і CPHA у SPI? По якому фронту захоплюються дані у Mode 0?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          <strong>CPOL</strong> — рівень CLK у стані спокою: <code class="ic">CPOL=0</code> → LOW,
          <code class="ic">CPOL=1</code> → HIGH.
          <p class="mt-6"><strong>CPHA</strong> — по якому фронту захоплюються дані:
          <code class="ic">CPHA=0</code> → перший фронт, <code class="ic">CPHA=1</code> → другий фронт.</p>
          <p class="mt-6"><strong>SPI Mode 0</strong> (CPOL=0, CPHA=0): CLK у спокої LOW,
          захоплення по <em>наростаючому</em> (першому) фронту, виставлення даних по спадаючому.
          Найпоширеніший режим — BME280, MPU-6050, W25Qxx.</p>
          <p class="mt-6">Типова пастка: "перший фронт" ≠ "наростаючий". При CPOL=1 перший
          фронт — спадаючий.</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Що таке ringing і як він пов'язаний з крутизною фронту?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          <strong>Ringing</strong> — загасаючі осциляції після фронту. Виникають через LC-резонанс:
          <code class="ic">L</code> доріжки (нГн/мм) + паразитна <code class="ic">C</code> навантаження.
          <p class="mt-6">Крутий фронт має широкий спектр гармонік → більша енергія в резонансній
          частоті → сильніший ringing. На осцилографі виглядає як хвилі після фронту. Може
          спричинити подвійне спрацювання EXTI.</p>
          <p class="mt-6">Рішення:
          <strong>1)</strong> Зменшити slew rate через <code class="ic">OSPEEDR</code>.
          <strong>2)</strong> Послідовний резистор 22–100 Ом на виході GPIO (série damping) — 
          гасить коливання без зміни логіки.
          <strong>3)</strong> Суцільний ground plane та короткі доріжки.</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Поясніть шлях тактового сигналу від кварцу до GPIO на STM32F4.</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          Ланцюг: <strong>HSE</strong> (кварц 8–25 МГц) → <strong>PLL</strong> (множення, до 168 МГц) →
          <strong>SYSCLK</strong> → шини <strong>AHB → APB1/APB2</strong> → периферія.
          <p class="mt-6">GPIO тактується від AHB1 (до 168 МГц на F4). Таймери на APB1 отримують
          половину AHB, але якщо APBx prescaler ≠ 1 — таймери автоматично подвоюють свою частоту.</p>
          <p class="mt-6">Основний генератор фронтів — <strong>PLL всередині МК</strong>. Кварц задає
          точну базову частоту. Без кварцу HSI (RC-генератор) має похибку ~1% — критично для
          UART (допустиме відхилення < 2% для надійного прийому).</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Чому при натисканні кнопки виникає багато фронтів? Як усунути дребезг?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          Механічні контакти при замиканні <strong>відбиваються</strong> (bouncing) — фізично
          розмикаються та замикаються 5–50 разів протягом 5–20 мс до стабілізації.
          MCU з EXTI фіксує кожен перехід як окремий фронт.
          <p class="mt-6"><strong>Апаратне рішення:</strong> RC-фільтр (10 кОм + 100 нФ) + тригер
          Шмітта або компаратор — фронти згладжуються, перехід відбувається один раз.</p>
          <p class="mt-6"><strong>Програмне рішення (STM32):</strong> у ISR запустити TIM з
          автозупинкою на 20 мс. Якщо GPIO стабільний після таймера — вважати натискання дійсним.
          <strong>ESP32 + FreeRTOS:</strong> з ISR відправити подію в Queue, таск обробляє з
          debounce-логікою без блокування.</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>На осцилографі UART TX іноді пропускає старт-біт. Що перевіряти?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          Старт-біт UART — завжди <strong>спадаючий фронт</strong> (HIGH→LOW). Можливі причини:
          <p class="mt-6"><strong>1) Baud Rate розбіжність > 2–3%.</strong> Виникає при HSI без
          кварцу або неправильному дільнику. Перевір: <code class="ic">USART_BRR = PCLK / BaudRate</code>.
          Навіть 3% розбіжність на 115200 дає збій кожні кілька байт.</p>
          <p class="mt-6"><strong>2) Повільний фронт.</strong> Велика ємність лінії (довгий кабель)
          розтягує спадаючий фронт — приймач не встигає розпізнати старт-біт до вибірки середини
          першого біт-інтервалу.</p>
          <p class="mt-6"><strong>3) Шум.</strong> Спайк на лінії імітує старт-біт → фреймінг-помилка
          → наступний справжній старт-біт ігнорується. Рішення: 100 нФ між TX і GND, або перехід
          на RS-485 (диференційна пара).</p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <button class="accordion-trigger" onclick="toggleAccordion(this)">
        <span>Які регістри STM32 керують швидкістю фронту GPIO і коли це важливо?</span>
        <span class="accordion-icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-content">
          Регістр <code class="ic">GPIOx_OSPEEDR</code> — два біти на кожен пін:
          <code class="ic">00</code>=LOW (~2 МГц), <code class="ic">01</code>=MEDIUM (~25 МГц),
          <code class="ic">10</code>=HIGH (~50 МГц), <code class="ic">11</code>=VERY_HIGH (~100 МГц).
          <p class="mt-6">Важливо обрати правильне значення: LOW для LED і загальних GPIO (менше EMI),
          MEDIUM для UART і I²C, HIGH для SPI, VERY_HIGH лише для USB, Ethernet і FMC де
          потрібна максимальна швидкість фронту.</p>
          <p class="mt-6">Поширена помилка: залишити VERY_HIGH для всіх пінів після дефолтної
          ініціалізації. Це призводить до зайвого EMI-шуму і потенційного ringing на довгих
          доріжках, навіть якщо сигнали низькочастотні.</p>
        </div>
      </div>
    </div>

  </div><!-- /accordion -->


  <div class="page-footer">
    // Конспект · Embedded Systems Notes · Anton Bodnia
  </div>

</div><!-- /page-wrap -->

<script>
  /* ── Accordion ── */
  function toggleAccordion(btn) {
    var body   = btn.nextElementSibling;
    var isOpen = btn.classList.contains('open');
    document.querySelectorAll('.accordion-trigger.open').forEach(function(b) {
      b.classList.remove('open');
      b.nextElementSibling.classList.remove('open');
    });
    if (!isOpen) { btn.classList.add('open'); body.classList.add('open'); }
  }

  /* ── Copy buttons ── */
  document.querySelectorAll('.code-block-copy').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var code = this.closest('.code-block').querySelector('.code-block-body').innerText;
      navigator.clipboard.writeText(code).catch(function(){});
      var orig = this.textContent;
      this.textContent = 'copied!';
      this.style.color = 'var(--accent)';
      var self = this;
      setTimeout(function() { self.textContent = orig; self.style.color = ''; }, 1500);
    });
  });

  /* ═══════════════════════════════════════════════
     WAVEFORM CANVAS
  ═══════════════════════════════════════════════ */
  window.addEventListener('DOMContentLoaded', function() {

    var wc   = document.getElementById('waveCanvas');
    var wctx = wc.getContext('2d');
    var tc   = document.getElementById('timingCanvas');
    var tctx = tc.getContext('2d');
    var animId  = null;
    var playing = true;
    var t = 0;

    function resizeC(c) {
      var w = Math.max(200, c.parentElement.clientWidth);
      c.width = w;
      return w;
    }

    function getSlope() { return parseInt(document.getElementById('slopeSlider').value, 10); }

    function sigmoid(phase, slope) {
      var k = 20 / slope;
      return 1 / (1 + Math.exp(-k * (phase - 0.5)));
    }
    function clkFn(x, per, slope) {
      var p = ((x % per) + per) % per / per;
      if (p < 0.03)       return sigmoid(p / 0.03, slope);
      if (p < 0.5)        return 1;
      if (p < 0.53)       return 1 - sigmoid((p - 0.5) / 0.03, slope);
      return 0;
    }
    function dataFn(x, per, slope) {
      var p2 = per * 2, off = per * 0.3;
      var p  = ((x + off) % p2 + p2) % p2 / p2;
      if (p < 0.03)       return sigmoid(p / 0.03, slope);
      if (p < 0.5)        return 1;
      if (p < 0.53)       return 1 - sigmoid((p - 0.5) / 0.03, slope);
      return 0;
    }
    function trigFn(x, per, slope) {
      var p3 = per * 1.7;
      var p  = ((x * 0.59) % p3 + p3) % p3 / p3;
      if (p < 0.03)       return sigmoid(p / 0.03, slope * 1.5);
      if (p < 0.38)       return 1;
      if (p < 0.41)       return 1 - sigmoid((p - 0.38) / 0.03, slope * 1.5);
      return 0;
    }

    var SIGS = [
      { name: 'CLK',     color: '#4a9eff', fn: clkFn  },
      { name: 'DATA',    color: '#00d084', fn: dataFn },
      { name: 'TRIGGER', color: '#ff6b4a', fn: trigFn },
    ];

    function drawWave() {
      var W     = wc.width, H = wc.height;
      var slope = getSlope(), per = 120;
      var rowH  = H / SIGS.length;

      wctx.clearRect(0, 0, W, H);

      /* grid */
      wctx.strokeStyle = 'rgba(255,255,255,0.04)';
      wctx.lineWidth = 1;
      for (var gx = 0; gx < W; gx += 60) {
        wctx.beginPath(); wctx.moveTo(gx, 0); wctx.lineTo(gx, H); wctx.stroke();
      }
      for (var i = 0; i <= SIGS.length; i++) {
        wctx.beginPath(); wctx.moveTo(0, i*rowH); wctx.lineTo(W, i*rowH); wctx.stroke();
      }

      /* rising-edge guides */
      wctx.setLineDash([2, 5]);
      wctx.strokeStyle = 'rgba(74,158,255,0.2)';
      wctx.lineWidth = 1;
      for (var px = 2; px < W; px++) {
        var v0 = clkFn(px-1+t, per, slope), v1 = clkFn(px+t, per, slope);
        if (v1 - v0 > 0.1) {
          wctx.beginPath(); wctx.moveTo(px, 0); wctx.lineTo(px, H); wctx.stroke();
        }
      }
      wctx.setLineDash([]);

      /* signals */
      SIGS.forEach(function(sig, idx) {
        var yBot = (idx+1)*rowH - 8, yTop = idx*rowH + 8, amp = yBot - yTop;
        wctx.strokeStyle = sig.color;
        wctx.lineWidth   = 1.5;
        wctx.shadowColor = sig.color;
        wctx.shadowBlur  = 4;
        wctx.beginPath();
        for (var px2 = 0; px2 <= W; px2++) {
          var v = sig.fn(px2+t, per, slope);
          var y = yBot - v * amp;
          px2 === 0 ? wctx.moveTo(px2, y) : wctx.lineTo(px2, y);
        }
        wctx.stroke();
        wctx.shadowBlur = 0;
        /* label */
        wctx.fillStyle = sig.color;
        wctx.font = '10px JetBrains Mono';
        wctx.fillText(sig.name, 6, yTop + 13);
      });
    }

    function loop() {
      if (!playing) return;
      resizeC(wc);
      drawWave();
      t += 1.2;
      animId = requestAnimationFrame(loop);
    }

    /* controls */
    document.getElementById('btnPlay').addEventListener('click', function() {
      if (!playing) { playing = true; loop(); }
      this.classList.add('active');
      document.getElementById('btnPause').classList.remove('active');
    });
    document.getElementById('btnPause').addEventListener('click', function() {
      playing = false; cancelAnimationFrame(animId);
      this.classList.add('active');
      document.getElementById('btnPlay').classList.remove('active');
    });
    document.getElementById('btnReset').addEventListener('click', function() {
      t = 0;
      if (!playing) { resizeC(wc); drawWave(); }
    });
    document.getElementById('slopeSlider').addEventListener('input', function() {
      document.getElementById('slopeVal').textContent = this.value + ' нс';
    });

    /* tooltip */
    var tooltip = document.getElementById('wave-tooltip');
    wc.addEventListener('mousemove', function(e) {
      var rect = wc.getBoundingClientRect();
      var mx = (e.clientX - rect.left) * (wc.width / rect.width);
      var my = (e.clientY - rect.top)  * (wc.height / rect.height);
      var rowH = wc.height / SIGS.length;
      var idx  = Math.max(0, Math.min(SIGS.length-1, Math.floor(my/rowH)));
      var sig  = SIGS[idx];
      var v    = sig.fn(mx+t, 120, getSlope());
      var tns  = Math.round(mx / wc.width * 5000);
      tooltip.innerHTML = '<span style="color:' + sig.color + '">' + sig.name + '</span>  ' +
                          (v > 0.5 ? 'HIGH' : 'LOW') + '  ~' + tns + ' нс';
      tooltip.style.left = (e.clientX + 12) + 'px';
      tooltip.style.top  = (e.clientY - 8)  + 'px';
      tooltip.style.opacity = '1';
    });
    wc.addEventListener('mouseleave', function() { tooltip.style.opacity = '0'; });

    /* ── TIMING DIAGRAM ── */
    function drawTiming() {
      var W = Math.max(200, tc.parentElement.clientWidth);
      tc.width = W;
      var H = tc.height;
      tctx.clearRect(0, 0, W, H);

      var yH  = H * 0.10, yL  = H * 0.87;
      var y90 = yL - (yL-yH)*0.9, y10 = yL - (yL-yH)*0.1;
      var x0=W*0.08, xR1=W*0.20, xR2=W*0.37, xF1=W*0.57, xF2=W*0.74, x1=W*0.94;

      /* grid */
      tctx.strokeStyle = 'rgba(255,255,255,0.04)';
      tctx.lineWidth = 1;
      for (var gx=0; gx<W; gx+=40) {
        tctx.beginPath(); tctx.moveTo(gx,0); tctx.lineTo(gx,H); tctx.stroke();
      }

      /* waveform */
      tctx.strokeStyle = '#00d084';
      tctx.lineWidth   = 2;
      tctx.shadowColor = '#00d084';
      tctx.shadowBlur  = 6;
      tctx.beginPath();
      tctx.moveTo(x0, yL); tctx.lineTo(xR1, yL);
      tctx.bezierCurveTo(xR1+(xR2-xR1)*0.3,yL, xR2-(xR2-xR1)*0.3,yH, xR2,yH);
      tctx.lineTo(xF1,yH);
      tctx.bezierCurveTo(xF1+(xF2-xF1)*0.3,yH, xF2-(xF2-xF1)*0.3,yL, xF2,yL);
      tctx.lineTo(x1,yL);
      tctx.stroke(); tctx.shadowBlur=0;

      /* dashed refs */
      function hline(y, color, lbl) {
        tctx.setLineDash([3,5]); tctx.strokeStyle=color; tctx.lineWidth=1;
        tctx.beginPath(); tctx.moveTo(x0,y); tctx.lineTo(x1,y); tctx.stroke();
        tctx.setLineDash([]);
        tctx.fillStyle=color; tctx.font='10px JetBrains Mono';
        tctx.fillText(lbl, 4, y+4);
      }
      hline(y90,'rgba(0,208,132,0.5)','90%');
      hline(y10,'rgba(0,208,132,0.5)','10%');
      hline(yH, 'rgba(255,255,255,0.15)','HIGH');
      hline(yL, 'rgba(255,255,255,0.15)','LOW');

      /* arrows */
      function arrowH(xa,xb,y,color,lbl) {
        tctx.strokeStyle=color; tctx.fillStyle=color; tctx.lineWidth=1.5;
        tctx.beginPath(); tctx.moveTo(xa,y); tctx.lineTo(xb,y); tctx.stroke();
        tctx.beginPath(); tctx.moveTo(xa,y); tctx.lineTo(xa+6,y-3); tctx.lineTo(xa+6,y+3); tctx.closePath(); tctx.fill();
        tctx.beginPath(); tctx.moveTo(xb,y); tctx.lineTo(xb-6,y-3); tctx.lineTo(xb-6,y+3); tctx.closePath(); tctx.fill();
        tctx.font='bold 11px JetBrains Mono'; tctx.fillText(lbl,(xa+xb)/2-6,y-8);
      }
      arrowH(xR1+(xR2-xR1)*0.1, xR1+(xR2-xR1)*0.9, y90-22, '#00d084', 'tᵣ');
      arrowH(xF1+(xF2-xF1)*0.1, xF1+(xF2-xF1)*0.9, y10-22, '#ff6b4a', 'tᶠ');

      tctx.fillStyle='rgba(255,255,255,0.2)'; tctx.font='10px JetBrains Mono';
      tctx.fillText('3.3V', W-36, yH+12);
      tctx.fillText('0V',   W-26, yL+12);
    }

    /* start */
    resizeC(wc);
    drawTiming();
    loop();

    window.addEventListener('resize', function() {
      drawTiming();
      if (!playing) { resizeC(wc); drawWave(); }
    });
  });
</script>

</body>
